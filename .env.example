# Spotify API Credentials
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Web UI redirect URI (used by app.py)
# You MUST also register this in your Spotify Developer Dashboard
SPOTIFY_WEB_REDIRECT_URI=http://127.0.0.1:5000/api/auth/callback

# CLI redirect URI (used by sync_to_spotify.py)
# You MUST also register this in your Spotify Developer Dashboard
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
